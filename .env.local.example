# Draftly Frontend Environment Variables
# Copy this file to frontend/.env.local and fill in values.
# NEVER commit frontend/.env.local — it is gitignored.
#
# For backend (FastAPI on Railway) see backend/.env.example
#
# NEXT_PUBLIC_ vars are exposed to the browser — keep them truly public.
# All other vars are server-side only (Next.js API routes).

# ---------------------------------------------------------------------------
# BROWSER-SAFE — exposed to client bundle (NEXT_PUBLIC_ prefix)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...            # anon/public key — safe to expose
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...  # pk_test_... for local dev
NEXT_PUBLIC_API_URL=http://localhost:8000        # Railway URL in prod

# ---------------------------------------------------------------------------
# SERVER-SIDE ONLY — Next.js API routes (never exposed to browser)
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # service role — used by /api/auth/create-customer
ANTHROPIC_API_KEY=sk-ant-...            # used by /api/demo/draftly streaming route
OPENAI_API_KEY=sk-proj-...             # used by /api/demo/generic streaming route
STRIPE_SECRET_KEY=sk_live_...          # sk_test_... for local dev
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...         # $99/mo
STRIPE_PRICE_PROFESSIONAL=price_...    # $249/mo
RESEND_API_KEY=re_...
