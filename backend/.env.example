# Draftly Backend Environment Variables
# Copy to backend/.env and fill in values.
# NEVER commit backend/.env — it is gitignored.

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # service role — NEVER expose to browser
SUPABASE_ANON_KEY=eyJ...

# ---------------------------------------------------------------------------
# Anthropic (PRIMARY LLM — Claude Sonnet 4.6)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# OpenAI (EMBEDDINGS ONLY — text-embedding-3-large)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# ---------------------------------------------------------------------------
# Pinecone (Vector DB — per-customer namespaces)
# ---------------------------------------------------------------------------
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=draftly-context-mapper

# ---------------------------------------------------------------------------
# Upstash Redis (async job queue + 72hr LLM response cache)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...           # sk_test_... for local dev
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# Resend (transactional email)
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_...

# ---------------------------------------------------------------------------
# HubSpot CRM
# ---------------------------------------------------------------------------
HUBSPOT_CLIENT_ID=...
HUBSPOT_CLIENT_SECRET=...
HUBSPOT_REDIRECT_URI=https://app.draftly.ai/crm/hubspot/callback

# ---------------------------------------------------------------------------
# Pipedrive CRM
# ---------------------------------------------------------------------------
PIPEDRIVE_API_KEY=...

# ---------------------------------------------------------------------------
# Ops
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/...   # churn alerts + HIGH ticket escalation
